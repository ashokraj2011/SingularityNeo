# =============================================================================
# Singularity Neo — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development.
# For desktop operators: only variables marked [DESKTOP] are typically needed.
# Variables marked REQUIRED must be set before the server will start correctly.
# Variables marked OPTIONAL fall back to the shown default when unset.
# =============================================================================

# --- LLM Provider (pick one or more) ----------------------------------------

# [REQUIRED for inference] GitHub Copilot CLI (preferred for enterprise).
# Point at a running headless Copilot CLI server, e.g. http://127.0.0.1:4321
COPILOT_CLI_URL=""

# [OPTIONAL] Token-based HTTP fallback when not using a Copilot CLI server.
# Create a token with `models` scope, or `models: read` for a fine-grained PAT.
GITHUB_MODELS_TOKEN="github_pat_your_token_here"

# [OPTIONAL] Override the GitHub Models REST API base URLs (seldom needed).
GITHUB_MODELS_API_URL=""
GITHUB_MODELS_HTTP_API_URL=""

# [OPTIONAL] Allow HTTP (non-CLI) model access even when COPILOT_CLI_URL is set.
# Default: false
ALLOW_GITHUB_MODELS_HTTP_FALLBACK="false"

# [OPTIONAL] Generic GitHub token used by the GitHub API client for repo access.
GH_TOKEN=""
GITHUB_TOKEN=""

# --- OpenAI-compatible providers (alternative to GitHub Models) --------------

# [OPTIONAL] Local or self-hosted OpenAI-compatible endpoint.
LOCAL_OPENAI_BASE_URL=""
LOCAL_OPENAI_API_KEY=""
LOCAL_OPENAI_DEFAULT_MODEL=""
LOCAL_OPENAI_EMBEDDING_MODEL=""

# [OPTIONAL] Alias for the OpenAI-compatible provider config.
OPENAI_COMPAT_BASE_URL=""
OPENAI_COMPAT_API_KEY=""
OPENAI_COMPAT_MODEL=""
OPENAI_COMPAT_EMBEDDING_MODEL=""

# [OPTIONAL] Google Gemini — uses the official OpenAI-compatible endpoint.
# Get a free API key at https://aistudio.google.com/app/apikey
# Aliases: GOOGLE_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY
GEMINI_API_KEY=""
GEMINI_DEFAULT_MODEL="gemini-2.0-flash"
# Only set GEMINI_BASE_URL if you're using a Vertex AI proxy or custom endpoint.
# Default: https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_BASE_URL=""

# [OPTIONAL] Custom OpenAI-compatible router (OpenCode, OpenRouter, LiteLLM,
# Together AI, Groq, Anyscale, etc.). Any endpoint that speaks the OpenAI
# chat-completions API is supported.
#
# Examples:
#   OpenRouter:  CUSTOM_ROUTER_BASE_URL="https://openrouter.ai/api/v1"
#   Groq:        CUSTOM_ROUTER_BASE_URL="https://api.groq.com/openai/v1"
#   Together AI: CUSTOM_ROUTER_BASE_URL="https://api.together.xyz/v1"
#   OpenCode:    CUSTOM_ROUTER_BASE_URL="http://localhost:4000/v1"
#   LiteLLM:     CUSTOM_ROUTER_BASE_URL="http://localhost:8000"
CUSTOM_ROUTER_BASE_URL=""
CUSTOM_ROUTER_API_KEY=""
CUSTOM_ROUTER_DEFAULT_MODEL=""
# Display name shown in the UI (e.g. "OpenRouter", "Groq", "OpenCode")
CUSTOM_ROUTER_LABEL="Custom Router"

# --- Server ------------------------------------------------------------------

# [OPTIONAL] HTTP port the Express API listens on. Default: 3001
PORT="3001"

# [OPTIONAL] Public URL of this server (used for self-referential links and
# OAuth callbacks). Set this in production to your HTTPS URL.
# Default: http://localhost:$PORT
APP_URL="http://localhost:3001"

# [OPTIONAL] Node environment. Set to "production" in production deployments.
# Default: development
NODE_ENV="development"

# --- Database (PostgreSQL) ---------------------------------------------------

# [REQUIRED] PostgreSQL connection details.
PGHOST="127.0.0.1"
PGPORT="5432"
PGDATABASE="singularity"
PGUSER="postgres"
PGPASSWORD=""
PGADMIN_DATABASE="postgres"     # Admin DB used to create the singularity DB

# --- Desktop executor (set in operator's .env.local) -------------------------

# [DESKTOP] Root directory where the desktop worker clones repos and runs
# agent tool calls. Each operator sets this once; it overrides any
# capability-level workspace paths configured in the UI.
# Example: SINGULARITY_WORKING_DIRECTORY="/Users/alice/code"
SINGULARITY_WORKING_DIRECTORY=""

# [DESKTOP] URL of the control plane the desktop worker registers with.
# Default: http://127.0.0.1:3001
SINGULARITY_CONTROL_PLANE_URL="http://127.0.0.1:3001"

# [DESKTOP] Stable executor ID. Auto-generated as a UUID on first run;
# override to pin the same ID across restarts on the same machine.
SINGULARITY_DESKTOP_EXECUTOR_ID=""

# [DESKTOP] Absolute path to the project root the desktop worker watches.
SINGULARITY_PROJECT_ROOT=""

# [DESKTOP, dev only] Electron dev server URL for hot-reload.
SINGULARITY_ELECTRON_DEV_SERVER_URL=""

# --- Agent sandbox -----------------------------------------------------------

# [OPTIONAL] Sandbox mode for agent shell command execution.
# "docker" — runs commands in isolated containers with resource limits (recommended for production).
# "local"  — runs commands in the operator's shell with no isolation (dev only).
# Default: local
SINGULARITY_SANDBOX_MODE="local"

# [OPTIONAL] Docker image tags used for each workflow phase sandbox.
# Only relevant when SINGULARITY_SANDBOX_MODE=docker.
SINGULARITY_SANDBOX_IMAGE_WORKSPACE=""
SINGULARITY_SANDBOX_IMAGE_BUILD=""
SINGULARITY_SANDBOX_IMAGE_TEST=""
SINGULARITY_SANDBOX_IMAGE_DOCS=""
SINGULARITY_SANDBOX_IMAGE_DEPLOY=""

# [OPTIONAL] Docker sandbox resource limits.
# Default: 1024m memory, 1.5 CPUs
SINGULARITY_SANDBOX_MEMORY="1024m"
SINGULARITY_SANDBOX_CPUS="1.5"

# --- Code intelligence -------------------------------------------------------

# [OPTIONAL] Java binary paths for Java AST parsing.
# If unset, the server tries JAVA_HOME, then searches PATH.
JAVA_BIN=""
JAVA_HOME=""
JAVAC_BIN=""
SINGULARITY_JAVA_BIN=""
SINGULARITY_JAVAC_BIN=""

# [OPTIONAL] Python binary for Python analysis tools.
# Tried in order: SINGULARITY_PYTHON_BIN → PYTHON3 → PYTHON → "python3"
SINGULARITY_PYTHON_BIN=""
PYTHON3=""
PYTHON=""

# --- Governance --------------------------------------------------------------

# [OPTIONAL] Ed25519 signing key for evidence packet attestations.
# Provision a key with `npm run governance:init-key`.
# Without these, packets are created but signed with signature=NULL.
GOVERNANCE_SIGNING_KEY_PATH=""
GOVERNANCE_SIGNING_KEYS_PATH=""        # Alternative multi-key path
GOVERNANCE_SIGNING_ACTIVE_KEY_ID=""
GOVERNANCE_SIGNING_KEY_PEM=""          # Inline PEM (alternative to path)

# [OPTIONAL] Enable/disable governance exception lifecycle.
# When true, an approved unexpired exception flips policy from REQUIRE_APPROVAL to ALLOW.
# Default: true
GOVERNANCE_EXCEPTIONS_ENABLED="true"

# [OPTIONAL] Enable/disable provenance "prove-no-touch" queries.
# Default: true
GOVERNANCE_PROVENANCE_ENABLED="true"

# --- Agent learning ----------------------------------------------------------

# [OPTIONAL] Enable/disable agent learning drift detection background jobs.
# Default: false (opt-in)
LEARNING_DRIFT_ENABLED="false"

# [OPTIONAL] Dry-run mode for drift detection (logs findings without applying).
# Default: true
LEARNING_DRIFT_DRY_RUN="true"

# [OPTIONAL] Enable quality gate checks on learning updates.
# Default: false
LEARNING_QUALITY_GATE_ENABLED="false"

# --- Execution mode ----------------------------------------------------------

# [OPTIONAL] Override execution runtime mode.
# "desktop" — delegates tool execution to the registered desktop executor.
# "server"  — runs tools directly on the server (for testing / CI).
# Default: determined automatically from executor registration.
EXECUTION_RUNTIME_MODE=""

# --- Workspace database profiles ---------------------------------------------

# [OPTIONAL] Active database profile ID (for multi-database workspace support).
WORKSPACE_ACTIVE_DB_PROFILE_ID=""

# [OPTIONAL] Base64-encoded JSON array of database profile configs.
WORKSPACE_DB_PROFILES_B64=""

# --- Observability -----------------------------------------------------------

# [OPTIONAL] OpenTelemetry OTLP endpoint for traces and metrics.
# Example: http://localhost:4318 (for a local Jaeger/Tempo instance)
OTEL_EXPORTER_OTLP_ENDPOINT=""

# --- Demo / seed data --------------------------------------------------------

# [OPTIONAL] Enable demo fixture seed data. Set to "true" only when
# intentionally running with demo capabilities.
# Default: false
ENABLE_DEMO_SEED="false"
VITE_ENABLE_DEMO_MODE="false"

# --- Test credentials (CI only — do not set in production) ------------------

# TEST_GH_SECRET=""
# TEST_GHE_SECRET=""
# TEST_SN_SECRET=""
# TEST_DD_APP=""
# TEST_DD_SECRET=""
