# COPILOT_CLI_URL: Preferred long-term option for enterprise use.
# Point this at a running headless Copilot CLI server, for example:
# COPILOT_CLI_URL="http://127.0.0.1:4321"
COPILOT_CLI_URL=""

# GITHUB_MODELS_TOKEN: Optional token-based fallback when you are not using a
# headless Copilot CLI server. Create a token with the `models` scope, or
# `models: read` for a fine-grained PAT.
GITHUB_MODELS_TOKEN="github_pat_your_token_here"

# PORT: Local API server port. The Vite dev server proxies `/api` requests here.
PORT="3001"

# Keep seeded/demo capability data out of normal product flows.
# Set to "true" only when intentionally running the demo fixtures.
VITE_ENABLE_DEMO_MODE="false"
ENABLE_DEMO_SEED="false"

# Local Postgres connection for the capability workspace system of record.
# The Express API will connect here and create the `singularity` database if it
# does not already exist and the configured user has permission to create DBs.
PGHOST="127.0.0.1"
PGPORT="5432"
PGDATABASE="singularity"
PGUSER="postgres"
PGPASSWORD=""
PGADMIN_DATABASE="postgres"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Governance — Signed Change Attestations (Ed25519).
# Provision a key with `npm run governance:init-key`, then set the two env
# vars below so the backend can sign new evidence packets. Without these,
# packets are still created but land with signature=NULL (treated as v1
# unsigned). The public half of every known key lives in
# governance/signing-keys.json so downstream verifiers can check signatures
# offline with only the repo checkout.
GOVERNANCE_SIGNING_KEY_PATH=""
GOVERNANCE_SIGNING_ACTIVE_KEY_ID=""

# Governance — Exception lifecycle (Slice 3). When "true", an approved,
# unexpired exception flips evaluateToolPolicy from REQUIRE_APPROVAL to
# ALLOW and stamps exception_id on the audit row. Set to "false" to
# disable the policy hook while keeping CRUD + event history intact —
# useful for rolling the feature back without losing the request trail.
# Defaults to enabled when unset.
GOVERNANCE_EXCEPTIONS_ENABLED="true"

# Governance — Prove-the-negative provenance (Slice 4). When "true",
# /api/governance/provenance/prove-no-touch queries the indexed
# touched_paths column with gap-aware coverage. When "false", the API
# returns a conservative "inconclusive" without querying; the
# touched_paths column keeps populating at write time regardless, so
# the flag is reversible without data loss.
# Defaults to enabled when unset.
GOVERNANCE_PROVENANCE_ENABLED="true"
