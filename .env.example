# COPILOT_CLI_URL: Preferred long-term option for enterprise use.
# Point this at a running headless Copilot CLI server, for example:
# COPILOT_CLI_URL="http://127.0.0.1:4321"
COPILOT_CLI_URL=""

# GITHUB_MODELS_TOKEN: Optional token-based fallback when you are not using a
# headless Copilot CLI server. Create a token with the `models` scope, or
# `models: read` for a fine-grained PAT.
GITHUB_MODELS_TOKEN="github_pat_your_token_here"

# PORT: Local API server port. The Vite dev server proxies `/api` requests here.
PORT="3001"

# Keep seeded/demo capability data out of normal product flows.
# Set to "true" only when intentionally running the demo fixtures.
VITE_ENABLE_DEMO_MODE="false"
ENABLE_DEMO_SEED="false"

# Local Postgres connection for the capability workspace system of record.
# The Express API will connect here and create the `singularity` database if it
# does not already exist and the configured user has permission to create DBs.
PGHOST="127.0.0.1"
PGPORT="5432"
PGDATABASE="singularity"
PGUSER="postgres"
PGPASSWORD=""
PGADMIN_DATABASE="postgres"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
